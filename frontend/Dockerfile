FROM node:18-alpine AS build-stage

WORKDIR /app

COPY package*.json ./
RUN npm install

COPY . .

ARG VITE_AUTH_SERVICE_URL=http://localhost:8004
ARG VITE_USERS_SERVICE_URL=http://localhost:8003
ARG VITE_ACCOUNTS_SERVICE_URL=http://localhost:8001
ARG VITE_TRANSACTIONS_SERVICE_URL=http://localhost:8002
ARG VITE_AADHAR_SERVICE_URL=http://localhost:8005
ARG VITE_COMPANY_CRV_SERVICE_URL=http://localhost:8006
ARG VITE_NOTIFICATION_SERVICE_URL=http://localhost:8007
ARG VITE_PAYMENT_GATEWAY_URL=http://localhost:8008

ENV VITE_AUTH_SERVICE_URL=$VITE_AUTH_SERVICE_URL
ENV VITE_USERS_SERVICE_URL=$VITE_USERS_SERVICE_URL
ENV VITE_ACCOUNTS_SERVICE_URL=$VITE_ACCOUNTS_SERVICE_URL
ENV VITE_TRANSACTIONS_SERVICE_URL=$VITE_TRANSACTIONS_SERVICE_URL
ENV VITE_AADHAR_SERVICE_URL=$VITE_AADHAR_SERVICE_URL
ENV VITE_COMPANY_CRV_SERVICE_URL=$VITE_COMPANY_CRV_SERVICE_URL
ENV VITE_NOTIFICATION_SERVICE_URL=$VITE_NOTIFICATION_SERVICE_URL
ENV VITE_PAYMENT_GATEWAY_URL=$VITE_PAYMENT_GATEWAY_URL

RUN npm run build

FROM nginx:stable-alpine AS production-stage

COPY --from=build-stage /app/dist /usr/share/nginx/html
COPY nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
